{
  "manifest_version": 3,
  "name": "ChatGPT Bridge",
  "version": "1.0.0",
  "description": "Bridge between local tools and the ChatGPT web app via HTTP/WebSocket.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "http://127.0.0.1:11557/*",
    "ws://127.0.0.1:11558/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
