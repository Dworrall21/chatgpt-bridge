#!/bin/bash
# chatgpt-chat — Send a prompt to ChatGPT via the bridge
# Usage:
#   chatgpt-chat "Your prompt here"
#   chatgpt-chat --file prompt.txt
#   echo "prompt" | chatgpt-chat
#   chatgpt-chat --timeout 300 "long prompt"
#   chatgpt-chat --model-search "thinking" "deep analysis prompt"
#   chatgpt-chat -m o3 "complex reasoning prompt"
#   chatgpt-chat --conversation-id UUID "follow-up prompt"
#   chatgpt-chat --session-id KEY "follow-up prompt"
#   chatgpt-chat --messages-json history.json "final user turn"
#   chatgpt-chat --new "start fresh"
#   chatgpt-chat --health
#   chatgpt-chat --reload

set -eo pipefail

BRIDGE_URL="http://127.0.0.1:11557"
HOST_SCRIPT="$HOME/chatgpt-extension/bridge-host.py"

# Parse optional flags before positional args
TIMEOUT=10
CONVERSATION_ID=""
MODEL_SEARCH=""
SESSION_ID="${HERMES_SESSION_ID:-}"
MESSAGES_JSON=""
RESET_ONLY=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --timeout|-T)
      TIMEOUT="${2:?missing value for --timeout}"
      shift 2
      ;;
    --model-search|-m)
      MODEL_SEARCH="${2:?missing value for --model-search}"
      shift 2
      ;;
    --conversation-id|-c)
      CONVERSATION_ID="${2:?missing value for --conversation-id}"
      shift 2
      ;;
    --session-id|-s)
      SESSION_ID="${2:?missing value for --session-id}"
      shift 2
      ;;
    --messages-json)
      MESSAGES_JSON="${2:?missing value for --messages-json}"
      shift 2
      ;;
    --new)
      RESET_ONLY=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

case "${1:-}" in
  --reload)
    curl -s -X POST "$BRIDGE_URL/reload" 2>/dev/null
    exit 0
    ;;
  --health)
    curl -s "$BRIDGE_URL/health" 2>/dev/null || echo "Bridge not running"
    exit 0
    ;;
  --help|-h)
    cat <<USAGE
Usage: chatgpt-chat [--timeout N] [--model-search TERM] [--conversation-id UUID] [--session-id KEY] [--messages-json PATH] [--new] ["prompt" | --file PATH | stdin]
  "prompt"               Send a prompt string
  --file PATH            Send contents of a file as the prompt
  --timeout N            Set timeout in seconds (default: 10)
  --model-search TERM    Select a ChatGPT model before prompting (e.g. "thinking", "o3")
  -m TERM                Shorthand for --model-search
  --conversation-id UUID Continue an existing conversation
  -c UUID                Shorthand for --conversation-id
  --session-id KEY       Scope the ChatGPT conversation pin to a Hermes session key
  -s KEY                 Shorthand for --session-id
  --messages-json PATH   Send OpenAI-style messages from a JSON file (context bundle)
  --new                  Reset the pinned ChatGPT conversation before sending
  --health               Check bridge status
  --reload               Reload extension + ChatGPT tab
  -h / --help            Show this help
  echo "prompt" | chatgpt-chat   Read prompt from stdin

Model search examples:
  chatgpt-chat -m thinking "Think deeply about this math problem"
  chatgpt-chat --model-search o3 "Complex reasoning task"

Conversation continuity:
  After each response, the bridge prints the conversation_id.
  Pass it back with -c to continue the same thread:
    chatgpt-chat "first prompt"
    # → [conversation_id: abc-123]
    chatgpt-chat -c abc-123 "follow-up prompt"
USAGE
    exit 0
    ;;
  --file)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: chatgpt-chat --file <path>" >&2
      exit 1
    fi
    PROMPT=$(cat "$2")
    ;;
  "")
    if [ -t 0 ]; then
      echo "Usage: chatgpt-chat \"prompt\"  (or use --file, --health, --help)" >&2
      exit 1
    fi
    PROMPT=$(cat)
    ;;
  *)
    PROMPT="$*"
    ;;
esac

if [[ -z "${PROMPT:-}" && -z "${MESSAGES_JSON:-}" ]]; then
  if [[ "$RESET_ONLY" -eq 0 ]]; then
    echo "Error: empty prompt" >&2
    exit 1
  fi
fi

# Validate --timeout is a positive integer
if ! [[ "$TIMEOUT" =~ ^[0-9]+$ ]] || [[ "$TIMEOUT" -le 0 ]]; then
  echo "Error: --timeout must be a positive integer (got: $TIMEOUT)" >&2
  exit 1
fi

if [[ "$RESET_ONLY" -eq 1 ]]; then
  python3 - "$SESSION_ID" <<'PY'
import json, sys, subprocess
session_id = sys.argv[1] or None
payload = {"session_id": session_id} if session_id else {}
r = subprocess.run([
    "curl", "-s", "-X", "POST", "http://127.0.0.1:11557/new",
    "-H", "Content-Type: application/json",
    "-d", json.dumps(payload),
], capture_output=True, text=True)
if r.stdout.strip():
    print(r.stdout.strip())
if r.returncode != 0:
    print(r.stderr.strip(), file=sys.stderr)
    sys.exit(r.returncode)
PY
  [[ -z "${PROMPT:-}" && -z "${MESSAGES_JSON:-}" ]] && exit 0
fi

# Send prompt to bridge, parse JSON response
CURL_TIMEOUT=$(( TIMEOUT + 30 ))

# Build the payload, including conversation/session ids and model_search if set
export PROMPT TIMEOUT CONVERSATION_ID MODEL_SEARCH SESSION_ID MESSAGES_JSON CURL_TIMEOUT
python3 - <<'PY'
import json, os, subprocess, sys
from pathlib import Path

prompt = os.environ.get('PROMPT', '')
timeout = int(os.environ['TIMEOUT'])
conversation_id = os.environ.get('CONVERSATION_ID') or None
model_search = os.environ.get('MODEL_SEARCH') or None
session_id = os.environ.get('SESSION_ID') or None
messages_json = os.environ.get('MESSAGES_JSON') or None
curl_timeout = os.environ['CURL_TIMEOUT']

payload_dict = {'timeout': timeout}
if session_id:
    payload_dict['session_id'] = session_id
if conversation_id:
    payload_dict['conversation_id'] = conversation_id
if model_search:
    payload_dict['model_search'] = model_search

if messages_json:
    messages_path = Path(messages_json)
    payload_dict['messages'] = json.loads(messages_path.read_text())
    if prompt:
        payload_dict['messages'].append({'role': 'user', 'content': prompt})
else:
    payload_dict['prompt'] = prompt

payload = json.dumps(payload_dict)
result = subprocess.run([
    'curl', '-s', '--max-time', curl_timeout,
    '-X', 'POST', 'http://127.0.0.1:11557/chat',
    '-H', 'Content-Type: application/json',
    '-d', payload,
], capture_output=True, text=True)

if not result.stdout.strip():
    print('Error: no response from bridge (is it running?)', file=sys.stderr)
    sys.exit(1)

try:
    data = json.loads(result.stdout)
except json.JSONDecodeError as e:
    print(f'Parse error: {e}', file=sys.stderr)
    sys.exit(1)

if data.get('success'):
    print(data.get('text', data.get('response', '')))
    conv_id = data.get('conversation_id')
    conv_title = data.get('conversation_title')
    if conv_id:
        print(f'[conversation_id: {conv_id}]', file=sys.stderr)
    if conv_title:
        print(f'[conversation_title: {conv_title}]', file=sys.stderr)
else:
    print('Error:', data.get('error', 'unknown'), file=sys.stderr)
    sys.exit(1)
PY